# Troquim Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.

# Spring Profile
SPRING_PROFILES_ACTIVE=azure

# ===========================================
# OBRIGATÓRIO — Troquim Bot
# ===========================================

# UUID do negócio piloto (gerar com: uuidgen)
TROQUIM_PILOT_BUSINESS_ID=

# Chave de API administrativa (Bearer token para chamadas internas)
TROQUIM_ADMIN_API_KEY=

# ===========================================
# PostgreSQL
# ===========================================
POSTGRES_USER=troquim
POSTGRES_PASSWORD=

# ===========================================
# WhatsApp Cloud API (Meta)
# Desligada por padrão. Ativar somente com credenciais reais.
# ===========================================
TROQUIM_WHATSAPP_CLOUD_ENABLED=false
TROQUIM_WHATSAPP_VERIFY_TOKEN=
TROQUIM_WHATSAPP_APP_SECRET=
TROQUIM_WHATSAPP_ACCESS_TOKEN=
TROQUIM_WHATSAPP_PHONE_NUMBER_ID=
TROQUIM_WHATSAPP_WABA_ID=
TROQUIM_WHATSAPP_GRAPH_API_VERSION=v22.0
# Opcional — sobrescreve a base URL da Graph API (padrão: https://graph.facebook.com)
# TROQUIM_WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com

# ===========================================
# Evolution API (WhatsApp — legado, desligar se não usar)
# ===========================================
EVOLUTION_BASE_URL=
EVOLUTION_INSTANCE_NAME=
EVOLUTION_API_KEY=

# ===========================================
# Flyway — só ativar na primeira migração de banco legado
# ===========================================
# TROQUIM_FLYWAY_BASELINE_ON_MIGRATE=true
# ===========================================
# WhatsApp Flow (Meta) — Data Endpoint de agendamento
# Desligado por padrão. A chave privada é PEM PKCS#8 (com \n escapado numa linha).
# Gere o par com:
#   openssl genrsa -out flow-private.pem 2048
#   openssl pkcs8 -topk8 -inform PEM -in flow-private.pem -out flow-private-pkcs8.pem
#   openssl rsa -in flow-private.pem -pubout -out flow-public.pem
# A chave PÚBLICA é registrada na Meta; a PRIVADA nunca sai daqui.
# ===========================================
TROQUIM_WHATSAPP_FLOW_ENABLED=false
WHATSAPP_FLOW_PRIVATE_KEY=
# Preencher apenas se o PEM for "ENCRYPTED PRIVATE KEY"
WHATSAPP_FLOW_PRIVATE_KEY_PASSWORD=
# Id do Flow publicado no WhatsApp Manager. Sem ele (ou sem o nome), a agenda por
# Flow fica indisponível e a conversa segue pelo menu textual.
TROQUIM_WHATSAPP_FLOW_ID=
# Alternativa ao id, para ambientes onde só o nome é estável
TROQUIM_WHATSAPP_FLOW_NAME=
# Rótulo do botão (máx. 20 caracteres)
TROQUIM_WHATSAPP_FLOW_CTA=Abrir agenda
# true abre o Flow em modo draft — só para teste interno, exige acesso ao app da Meta
TROQUIM_WHATSAPP_FLOW_DRAFT=false
# Validade da sessão do Flow, em minutos
TROQUIM_WHATSAPP_FLOW_SESSAO_TTL_MIN=30
# Opcional — janela de dias oferecida no calendário (padrão: 30)
# TROQUIM_WHATSAPP_FLOW_JANELA_DIAS=30
