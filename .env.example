# Troquim Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Evolution API (WhatsApp integration)
EVOLUTION_BASE_URL=http://localhost:8082
EVOLUTION_INSTANCE_NAME=troquim-dev
EVOLUTION_API_KEY=your-api-key-here

# AI Configuration
AI_MODEL=llama3.1:8b
AI_TEMPERATURE=0.6
AI_MAX_TOKENS=500

# Conversation Mode
CONVERSATION_MODE=STRICT_MVP

# ===========================================
# WhatsApp Cloud API (Meta) — official integration
# Values below are FICTITIOUS placeholders. NEVER commit real secrets.
# Enable only when credentials are set. In azure with enabled=true the app
# fails fast if any required value is missing or has surrounding whitespace.
# ===========================================
TROQUIM_WHATSAPP_CLOUD_ENABLED=false
# Verify token: any high-entropy string YOU choose; must match the value typed
# in the Meta App dashboard when registering the callback URL.
TROQUIM_WHATSAPP_VERIFY_TOKEN=choose-a-long-random-verify-token
# App Secret: Meta App > Settings > Basic > App Secret (HMAC key for signatures).
TROQUIM_WHATSAPP_APP_SECRET=your-meta-app-secret
# Access token: WhatsApp > API Setup (temporary) or a System User token (permanent).
TROQUIM_WHATSAPP_ACCESS_TOKEN=your-graph-api-access-token
# Phone Number ID and WABA ID: WhatsApp > API Setup.
TROQUIM_WHATSAPP_PHONE_NUMBER_ID=000000000000000
TROQUIM_WHATSAPP_WABA_ID=000000000000000
# Graph API version: set explicitly to the version you tested against (e.g. vNN.N).
# Do NOT rely on a default — pin the version you validated in the Meta dashboard.
TROQUIM_WHATSAPP_GRAPH_API_VERSION=vNN.N
# Base URL: official default is https://graph.facebook.com (override only for tests).
TROQUIM_WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com